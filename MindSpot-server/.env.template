# MindSpot — Environment Secrets Template
# ------------------------------------------
# Rename this file to  .env  and fill in all values before running MindSpot.exe
# Never commit the filled-in .env to source control.

# ── JWT ──────────────────────────────────────────────────────────────────────
# Use a long, random string (≥32 chars).  Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_KEY=REPLACE_WITH_LONG_RANDOM_SECRET

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Required for the AI triage / therapist-matching feature.
OPENAI_API_KEY=sk-...

# ── Stripe ───────────────────────────────────────────────────────────────────
# Server-side secret key (starts with sk_live_ or sk_test_).
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret — copy from the Stripe dashboard after registering
# the endpoint  http://<your-host>:7160/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Public (publishable) key — shown to the browser via the React build.
# If you rebuild the frontend, set  VITE_STRIPE_PUBLISHABLE_KEY  to this value.
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── SendGrid ─────────────────────────────────────────────────────────────────
# Required for email notifications (appointment reminders, cancellations).
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ── Anthropic / Claude ───────────────────────────────────────────────────────
# Required for the AI therapist-license verification feature.
ANTHROPIC_API_KEY=sk-ant-...

# ── Encryption ───────────────────────────────────────────────────────────────
# AES-256 key for patient clinical-record encryption (Module 2).
# Must be exactly 32 bytes, base-64 encoded.  Generate with:
#   python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=REPLACE_WITH_BASE64_32BYTE_KEY

# ── RavenDB ──────────────────────────────────────────────────────────────────
# Default: local RavenDB on port 8080.  Change if using RavenDB Cloud or a
# remote server.  The database name is set in appsettings.json.
# RAVENDB_URLS=http://localhost:8080
